<%- include('partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
    <h1>오답 게시판</h1>
    <% if (user) { %>
        <a href="/write" class="btn btn-primary" style="padding: 10px 20px; font-size: 0.9rem;">새 오답 작성</a>
    <% } %>
</div>

<div class="notes-list">
    <% if (notes && notes.length > 0) { %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <% notes.forEach(note => { %>
                <a href="/post/<%= note.id %>" class="card" style="display: block; text-decoration: none; color: inherit; border: 1px solid #ddd; padding: 20px; border-radius: 8px;">
                    <span class="tag" style="background: #eee; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem;">
                        <%= note.type_name || '기타' %>
                    </span>
                    <h3 style="margin: 10px 0;"><%= note.title %></h3>
                    <p style="color: #666;"><%= note.solution.substring(0, 80) %><%= note.solution.length > 80 ? '...' : '' %></p>
                    <div style="margin-top: 15px; font-size: 0.8rem; color: #999; display: flex; justify-content: space-between;">
                        <span>작성자: <%= note.username || '익명' %></span>
                        <span><%= new Date(note.created_at).toLocaleDateString() %></span>
                    </div>
                </a>
            <% }); %>
        </div>
    <% } else { %>
        <div class="card" style="text-align: center; padding: 60px; border: 1px solid #ddd; border-radius: 8px;">
            <p>아직 등록된 오답 노트가 없습니다. 첫 번째 노트를 작성해 보세요!</p>
            <a href="/write" class="btn btn-primary" style="margin-top: 20px;">오답 작성하기</a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
