<%- include('partials/header') %>

<div style="max-width: 1000px; margin: auto;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #333;">
        <h2 style="margin: 0;">질문 게시판</h2>
        <a href="/questions/write" class="btn" style="background: #03c75a; font-weight: bold;">질문하기</a>
    </div>

    <table style="width: 100%; border-collapse: collapse; font-size: 0.95rem;">
        <thead>
            <tr style="background: #f8f9fa; border-bottom: 1px solid #ddd;">
                <th style="padding: 12px; text-align: left;">제목</th>
                <th style="padding: 12px; text-align: center; width: 120px;">작성자</th>
                <th style="padding: 12px; text-align: center; width: 100px;">날짜</th>
            </tr>
        </thead>
        <tbody>
            <% if (questions.length > 0) { %>
                <% questions.forEach(q => { %>
                    <tr style="border-bottom: 1px solid #eee; transition: background 0.2s;" onmouseover="this.style.background='#fcfcfc'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 12px;">
                            <a href="/questions/<%= q.id %>" style="text-decoration: none; color: #333; font-weight: 500;">
                                <%= q.title %>
                            </a>
                        </td>
                        <td style="padding: 12px; text-align: center; color: #666;"><%= q.username %></td>
                        <td style="padding: 12px; text-align: center; color: #888;">
                            <%= new Date(q.created_at).toLocaleDateString('ko-KR', {month: '2-digit', day: '2-digit'}) %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="3" style="padding: 50px; text-align: center; color: #999;">등록된 질문이 없습니다.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>
