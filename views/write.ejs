<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Re:View - 오답 작성</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <nav>
            <a href="/" class="logo">Re:View</a>
            <div class="nav-links">
                <a href="/board">게시판</a>
                <a href="/analysis">분석</a>
                <a href="/write">오답작성</a>
            </div>
        </nav>

        <h1>새 오답 작성</h1>

        <div class="card" style="padding: 40px; margin-top: 20px;">
            <form action="/write" method="POST">
                <div class="form-group">
                    <label for="title">문제 제목</label>
                    <input type="text" id="title" name="title" placeholder="예: 미적분 22번 (수능특강)" required>
                </div>

                <div class="form-group">
                    <label for="reason_id">틀린 원인</label>
                    <select id="reason_id" name="reason_id" required>
                        <option value="1">계산 실수</option>
                        <option value="2">문제 해석 오류</option>
                        <option value="3">개념 부족</option>
                        <option value="4">발상 실패</option>
                        <option value="5">시간 부족</option>
                        <option value="0">기타</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="problem_image_url">문제 이미지 URL (선택)</label>
                    <input type="text" id="problem_image_url" name="problem_image_url" placeholder="https://...">
                </div>

                <div class="form-group">
                    <label for="solution">나의 풀이 및 보완할 점</label>
                    <textarea id="solution" name="solution" rows="8" placeholder="틀린 과정과 정답을 기록하세요..." required></textarea>
                </div>

                <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="is_public" name="is_public" checked style="width: auto;">
                    <label for="is_public" style="margin: 0;">다른 학생과 공유하기</label>
                </div>

                <div class="btn-group" style="justify-content: flex-start; margin-top: 30px;">
                    <button type="submit" class="btn btn-primary">오답 저장하기</button>
                    <a href="/board" class="btn btn-secondary">취소</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
